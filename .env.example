# Kindle Trader AI · 环境变量示例
# 用法：复制本文件为 .env 并按需填写。未填写的变量将使用代码内置默认值（本地/演示模式）。
# 说明：本项目零依赖，server.js 启动时会自动读取项目根目录的 .env（仅填充未设置的变量，不覆盖系统环境）。

# ---- 服务 ----
# 监听端口（默认 3000）
PORT=3000

# 会话有效期（毫秒，默认 30 天 = 2592000000）
SESSION_TTL_MS=2592000000

# ---- 微信扫码登录 ----
# 留空则进入「演示模式」（前端弹模拟二维码即可体验完整流程）。
# 接入真实扫码需在微信开放平台登记回调域名，并将下方重定向地址加入白名单。
WECHAT_APPID=
WECHAT_SECRET=
# 回调地址（默认 http://localhost:PORT/api/auth/wechat/callback）
WECHAT_REDIRECT_URI=

# ---- 邮件发送（SMTP）----
# 留空则验证码仅打印到服务端控制台，并返回 devCode 便于本地校验。
# QQ/163 邮箱请使用「授权码」而非登录密码。
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Kindle Trader AI <no-reply@example.com>

# ---- 备注 ----
# 会话鉴权基于数据库会话 token（crypto.randomBytes 随机生成），无需 JWT 密钥。
# 接入公网部署时，请务必为上述各项配置真实值，并配合反向代理设置正确的信任前缀（X-Forwarded-For）。
