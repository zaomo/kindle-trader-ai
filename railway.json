{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "node --experimental-sqlite src/server.js",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "sleepApplication": false
  }
}
